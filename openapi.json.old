  "components": {
    "schemas": {
      "UserMediaEntity": {
        "type": "object",
        "properties": {
          "id": {
            "format": "int64",
            "type": "integer",
            "description": "The unique identifier for the media",
            "example": 1
          },
          "url": {
            "type": "string",
            "description": "The URL of the media file",
            "example": "https://example.com/media/image.jpg"
          },
          "type": {
            "type": "string",
            "description": "The type of media",
            "enum": [
              "IMAGE",
              "VIDEO",
              "DOCUMENT"
            ],
            "example": "IMAGE"
          },
          "isShopLogo": {
            "type": "boolean",
            "description": "Whether this media is a shop logo",
            "example": false
          },
          "isShopBanner": {
            "type": "boolean",
            "description": "Whether this media is a shop banner",
            "example": false
          },
          "isCategoryFile": {
            "type": "boolean",
            "description": "Whether this media is a category file",
            "example": false
          },
          "isAvatarFile": {
            "type": "boolean",
            "description": "Whether this media is an avatar file",
            "example": false
          },
          "createdAt": {
            "format": "date-time",
            "type": "string",
            "description": "The timestamp when the media was created",
            "example": "2025-01-20T10:00:00Z"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string",
            "description": "The timestamp when the media was last updated",
            "example": "2025-01-20T10:00:00Z"
          }
        },
        "required": [
          "id",
          "url",
          "type",
          "isShopLogo",
          "isShopBanner",
          "isCategoryFile",
          "isAvatarFile",
          "createdAt",
          "updatedAt"
        ]
      },
      "UserWithMediaEntity": {
        "type": "object",
        "properties": {
          "id": {
            "format": "int64",
            "type": "integer",
            "description": "The unique identifier for the user",
            "example": 1
          },
          "firstName": {
            "type": "string",
            "description": "The first name of the user",
            "example": "John",
            "nullable": true
          },
          "lastName": {
            "type": "string",
            "description": "The last name of the user",
            "example": "Doe",
            "nullable": true
          },
          "gender": {
            "type": "string",
            "description": "The gender of the user",
            "enum": [
              "MALE",
              "FEMALE",
              "OTHER"
            ],
            "example": "MALE",
            "nullable": true
          },
          "email": {
            "type": "string",
            "description": "The email address of the user",
            "example": "john.doe@example.com"
          },
          "phone": {
            "type": "string",
            "description": "The phone number of the user",
            "example": "0123456789",
            "nullable": true
          },
          "username": {
            "type": "string",
            "description": "The username of the user",
            "example": "johndoe"
          },
          "role": {
            "type": "string",
            "description": "The role of the user",
            "enum": [
              "USER",
              "ADMIN",
              "OPERATOR"
            ],
            "example": "USER"
          },
          "isActive": {
            "type": "boolean",
            "description": "Whether the user account is active",
            "example": true
          },
          "loyaltyCard": {
            "type": "string",
            "description": "The loyalty card number (for customers)",
            "example": "LC123456",
            "nullable": true
          },
          "staffCode": {
            "type": "string",
            "description": "The staff code (for staff members)",
            "example": "STAFF001",
            "nullable": true
          },
          "points": {
            "type": "number",
            "description": "User loyalty points",
            "example": 100
          },
          "userMedia": {
            "description": "Array of media files associated with the user (avatar, etc.)",
