          },
          "carrier": {
            "type": "string",
            "examples": [
              "Giao hàng nhanh",
              "Giao hàng tiết kiệm",
              "GrabExpress",
              "VNPost",
              "J&T Express"
            ],
            "description": "Carrier for the shipment",
            "example": "Giao hàng nhanh"
          },
          "description": {
            "type": "string",
            "example": "This is a description of the order",
            "description": "Description of the order"
          },
          "phone": {
            "type": "string",
            "example": "0987654321"
          },
          "packages": {
            "type": "object",
            "description": "Packages grouped by GHN shop ID. Each key is a shop ID string and each value is a PackageDetail object.",
            "additionalProperties": {
              "$ref": "#/components/schemas/PackageDetailDto"
            }
          },
          "shippingAddress": {
            "description": "Validated shipping address for order creation (database address plus GHN location data).",
            "allOf": [
              {
                "$ref": "#/components/schemas/CreateAddressForOrderResponseDto"
              }
            ]
          }
        },
        "required": [
          "userId",
          "paymentMethod",
          "carrier",
          "phone",
          "packages",
          "shippingAddress"
        ]
      },
