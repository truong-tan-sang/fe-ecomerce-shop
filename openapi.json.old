{
  "openapi": "3.0.0",
  "paths": {
    "/": {
      "get": {
        "operationId": "AppController_getHello",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Success."
          },
          "401": {
            "description": "Unauthorized."
          },
          "403": {
            "description": "Forbidden."
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Hello word!",
        "tags": [
          "App"
        ]
      }
    },
    "/user": {
      "get": {
        "operationId": "UserController_getAllUsers",
        "parameters": [
          {
            "name": "perPage",
            "required": false,
            "in": "query",
            "description": "Items per page (default 10)",
            "schema": {
              "example": 10,
              "type": "number"
            }
          },
          {
            "name": "page",
            "required": false,
            "in": "query",
            "description": "Page number (default 1)",
            "schema": {
              "example": 1,
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User list retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/UserWithMediaEntity"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Invalid pagination parameters or failed to retrieve users"
          },
          "401": {
            "description": "Unauthorized - No valid JWT token provided"
          },
          "403": {
            "description": "Forbidden - User does not have ADMIN or OPERATOR role"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Get user list",
        "tags": [
          "User"
        ]
      },
      "post": {
        "operationId": "UserController_createAnUser",
        "parameters": [],
        "requestBody": {
          "required": true,
          "description": "User creation data with avatar file",
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/CreateUserWithFileDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserWithMediaEntity"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Invalid input, missing fields, or email already exists"
          },
          "401": {
            "description": "Unauthorized - No valid JWT token provided"
          },
          "403": {
            "description": "Forbidden - Only ADMIN can create users"
          },
          "404": {
            "description": "Not Found - Related resource (role/department) not found"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Add a new user",
        "tags": [
          "User"
        ]
      }
    },
    "/user/{id}": {
      "get": {
        "operationId": "UserController_getUserDetailById",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "User ID",
            "schema": {
              "example": 1,
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User found!",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserWithMediaEntity"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request."
          },
          "401": {
            "description": "Unauthorized."
          },
          "403": {
            "description": "Forbidden."
          },
          "404": {
            "description": "Not Found."
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Get user detail by ID",
        "tags": [
          "User"
        ]
      },
      "delete": {
        "operationId": "UserController_deleteUserById",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "User ID",
            "schema": {
              "example": 1,
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserEntity"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Invalid user ID or unable to delete"
          },
          "401": {
            "description": "Unauthorized - No valid JWT token provided"
          },
          "403": {
            "description": "Forbidden - Insufficient permissions to delete user"
          },
          "404": {
            "description": "Not Found - User does not exist"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Delete a user",
        "tags": [
          "User"
        ]
      },
      "patch": {
        "operationId": "UserController_updateAnUser",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "User ID",
            "schema": {
              "example": 1,
              "type": "number"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "description": "User update data with optional avatar file",
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/UpdateUserWithFileDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserWithMediaEntity"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Invalid input or file upload failed"
          },
          "401": {
            "description": "Unauthorized - No valid JWT token provided"
          },
          "403": {
            "description": "Forbidden - Insufficient permissions to update user"
          },
          "404": {
            "description": "Not Found - User does not exist"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Update a user",
        "tags": [
          "User"
        ]
      }
    },
    "/user/google-account": {
      "post": {
        "operationId": "UserController_createAnUserByGoogleAccount",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateUserByGoogleAccountDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created successfully from Google account",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserEntity"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Invalid Google data or email already exists"
          }
        },
        "summary": "Add a new user by Google account",
        "tags": [
          "User"
        ]
      }
    },
