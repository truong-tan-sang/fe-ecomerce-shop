      "EnrichedPackageDetailEntity": {
        "type": "object",
        "properties": {
          "packageItems": {
            "type": "array",
            "items": {
              "type": "object"
            },
            "description": "Product variants in this package with pricing and discount information (ID, name, size, color, SKU, quantity, unitPrice, discountType, discountValue, totalPrice)"
          },
          "packageItemsForGHNCreateNewOrderRequest": {
            "type": "array",
            "items": {
              "type": "object"
            },
            "description": "Package items formatted for GHN create order API request (name, code, quantity, price, length, width, height, weight, category)"
          },
          "totalWeight": {
            "type": "number",
            "example": 1500,
            "description": "Total weight of all items in this package in grams"
          },
          "totalHeight": {
            "type": "number",
            "example": 20,
            "description": "Total height of stacked items in centimeters"
          },
          "maxLength": {
            "type": "number",
            "example": 30,
            "description": "Maximum length among all items in centimeters"
          },
          "maxWidth": {
            "type": "number",
            "example": 25,
            "description": "Maximum width among all items in centimeters"
          },
          "ghnShopId": {
            "type": "number",
            "example": 1001,
            "description": "GHN shop ID for the pickup location (warehouse/shop office)"
          },
          "ghnShopDetail": {
            "type": "object",
            "description": "Complete GHN shop details from GHN API (_id, name, phone, address, ward_code, district_id, location, version_no, is_created_chat_channel, address_v2, ward_id_v2, province_id_v2, status, updated/created metadata)"
          },
          "ghnProvinceName": {
            "type": "string",
            "example": "TP. Hồ Chí Minh",
            "description": "Province name for pickup location from GHN API"
          },
          "ghnDistrictName": {
            "type": "string",
            "example": "Quận 1",
            "description": "District name for pickup location from GHN API"
          },
          "ghnWardName": {
            "type": "string",
            "example": "Phường Bến Nghé",
            "description": "Ward name for pickup location from GHN API"
          },
          "shippingService": {
            "type": "object",
            "description": "Selected GHN shipping service details (service_id, short_name like \"Express/Standard/Saving\", service_type_id, config_fee_id, extra_cost_id, standard_config_fee_id, standard_extra_cost_id)"
          },
          "shippingFee": {
            "type": "number",
            "example": 35000,
            "description": "Calculated shipping fee for this package in VND"
          },
          "expectedDeliveryTime": {
            "type": "object",
            "description": "Expected delivery time with leadtime (Unix timestamp for delivery) and order_date (Unix timestamp for order creation)",
            "example": {
              "leadtime": 1707993600,
              "order_date": 1707917200
            }
          },
          "from_district_id": {
            "type": "number",
            "example": 1,
            "description": "GHN district ID for pickup location"
          },
          "from_ward_code": {
            "type": "string",
            "example": "100320",
            "description": "GHN ward code for pickup location"
          },
          "to_district_id": {
            "type": "number",
            "example": 3,
            "description": "GHN district ID for delivery location"
          },
          "to_ward_code": {
            "type": "string",
            "example": "100010",
            "description": "GHN ward code for delivery location"
          }
        },
        "required": [
          "packageItems",
          "packageItemsForGHNCreateNewOrderRequest",
          "totalWeight",
          "totalHeight",
          "maxLength",
          "maxWidth",
          "ghnShopId",
          "ghnShopDetail",
          "ghnProvinceName",
          "ghnDistrictName",
          "ghnWardName",
          "shippingService",
          "shippingFee",
          "expectedDeliveryTime",
          "from_district_id",
          "from_ward_code",
          "to_district_id",
          "to_ward_code"
        ]
      },
