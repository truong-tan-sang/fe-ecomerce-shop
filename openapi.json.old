      "BuildPaymentUrlDto": {
        "type": "object",
        "properties": {
          "vnp_Amount": {
            "type": "number",
            "description": "Payment amount (library will convert to VNPay unit: amount * 100)",
            "example": 150000
          },
          "vnp_OrderInfo": {
            "type": "string",
            "description": "Payment description (Vietnamese without accents)",
            "example": "Thanh toan don hang 12345"
          },
          "vnp_TxnRef": {
            "type": "string",
            "description": "Merchant transaction reference (must be unique per day)",
            "example": "ORDER_12345"
          },
          "vnp_IpAddr": {
            "type": "string",
            "description": "Customer IP address",
            "example": "13.160.92.202"
          },
          "vnp_ReturnUrl": {
            "type": "string",
            "description": "Return callback URL after payment",
            "example": "https://your-domain.com/payments/vnpay-return"
          },
          "vnp_CreateDate": {
            "type": "number",
            "description": "Optional create time format yyyyMMddHHmmss (GMT+7)",
            "example": 20260303153000
          },
          "vnp_ExpireDate": {
            "type": "number",
            "description": "Optional expire time format yyyyMMddHHmmss (GMT+7)",
            "example": 20260304153000
          },
          "vnp_CurrCode": {
            "type": "string",
            "description": "Currency code (currently only VND)",
            "enum": [
              "VND"
            ],
            "example": "VND"
          },
          "vnp_Locale": {
            "type": "string",
            "description": "Gateway language",
            "enum": [
              "vn",
              "en"
            ],
            "example": "vn"
          },
          "vnp_OrderType": {
            "type": "string",
            "description": "Order/product code",
            "example": "other"
          },
          "vnp_BankCode": {
            "type": "string",
            "description": "Optional bank code",
            "example": "NCB"
          }
        },
        "required": [
          "vnp_Amount",
          "vnp_OrderInfo",
          "vnp_TxnRef",
          "vnp_IpAddr",
          "vnp_ReturnUrl"
        ]
      },
      "BuildPaymentUrlOptionsDto": {
        "type": "object",
        "properties": {
          "withHash": {
            "type": "boolean",
            "description": "Include vnp_SecureHash in returned payment URL",
            "example": true
          },
          "logger": {
            "type": "object",
            "description": "Logger options (can be {type: \"all\"}, {type: \"omit\", fields: [...]}, or {type: \"pick\", fields: [...]})",
            "example": {
              "type": "all"
            }
          }
        }
      },
      "CreateVNPayPaymentUrlDto": {
        "type": "object",
        "properties": {
          "data": {
            "description": "BuildPaymentUrl payload for VNPay",
            "allOf": [
              {
                "$ref": "#/components/schemas/BuildPaymentUrlDto"
              }
            ]
          },
          "options": {
            "description": "Optional BuildPaymentUrlOptions for VNPay",
            "allOf": [
              {
                "$ref": "#/components/schemas/BuildPaymentUrlOptionsDto"
              }
            ]
          }
        },
        "required": [
          "data"
        ]
      },
      "ReturnQueryFromVNPayDto": {
        "type": "object",
        "properties": {
          "vnp_TmnCode": {
            "type": "string",
            "description": "Merchant TMN code - 8 alphanumeric characters",
            "example": "L62FDD2R"
          },
          "vnp_Amount": {
            "type": "string",
            "description": "Payment amount - Numeric string, VNPAY returns amount multiplied by 100",
            "example": "15000000"
          },
          "vnp_BankCode": {
            "type": "string",
            "description": "Bank code used for payment - 3-20 alphanumeric characters. Example: NCB",
            "example": "NCB"
          },
          "vnp_OrderInfo": {
            "type": "string",
            "description": "Payment description from original transaction - Vietnamese without accents",
            "example": "Thanh toan don hang 12345"
          },
          "vnp_TransactionNo": {
            "type": "string",
            "description": "Transaction code recorded in VNPAY system - 1-15 numeric characters",
            "example": "20170829153052"
          },
          "vnp_ResponseCode": {
            "type": "string",
            "description": "Response code from VNPAY (00 = success)",
            "example": "00"
          },
          "vnp_TransactionStatus": {
            "type": "string",
            "description": "Transaction status at VNPAY (00 = successful, others = failed)",
            "example": "00"
          },
          "vnp_TxnRef": {
            "type": "string",
            "description": "Merchant transaction reference from original request - 1-100 alphanumeric characters",
            "example": "ORDER_12345"
          },
          "vnp_SecureHash": {
            "type": "string",
            "description": "Secure hash from VNPAY callback - 32-256 alphanumeric characters for checksum verification",
            "example": "5CC2F6B77D96B5D7F3B5E4C3D2A1E9F8B7C6D5E4F3A2B1C0D9E8F7A6B5C4D3"
          },
          "vnp_BankTranNo": {
            "type": "string",
            "description": "Transaction code at bank - 1-255 alphanumeric characters",
            "example": "NCB20170829152730"
          },
          "vnp_CardType": {
            "type": "string",
            "description": "Type of account/card used: ATM, QRCODE",
            "example": "ATM"
          },
          "vnp_PayDate": {
            "type": "string",
            "description": "Payment date - Format: yyyyMMddHHmmss (14 numeric characters)",
            "example": "20170829152730"
          },
          "vnp_SecureHashType": {
            "type": "string",
            "description": "Secure hash type algorithm",
            "example": "HmacSHA512"
          }
        },
        "required": [
          "vnp_TmnCode",
          "vnp_Amount",
          "vnp_BankCode",
          "vnp_OrderInfo",
          "vnp_TransactionNo",
          "vnp_ResponseCode",
          "vnp_TransactionStatus",
          "vnp_TxnRef",
          "vnp_SecureHash"
        ]
      },
      "VerifyReturnUrlOptionsDto": {
        "type": "object",
        "properties": {
          "withHash": {
            "type": "boolean",
            "description": "Whether the secure hash is included in data",
            "example": true
          },
          "logger": {
            "type": "object",
            "description": "Logger options (can be {type: \"all\"}, {type: \"omit\", fields: [...]}, or {type: \"pick\", fields: [...]})",
            "example": {
              "type": "all"
            }
          }
        }
      },
      "VerifyVNPayReturnUrlDto": {
        "type": "object",
        "properties": {
          "data": {
            "description": "Return query data from VNPAY callback",
            "allOf": [
              {
                "$ref": "#/components/schemas/ReturnQueryFromVNPayDto"
              }
            ]
          },
          "options": {
            "description": "Optional verification options",
            "allOf": [
              {
                "$ref": "#/components/schemas/VerifyReturnUrlOptionsDto"
              }
            ]
          }
        },
        "required": [
          "data"
        ]
      },
      "VNPayVerifyReturnUrlResponseDto": {
        "type": "object",
        "properties": {
          "vnp_TmnCode": {
            "type": "string",
            "description": "Merchant TMN code",
            "example": "L62FDD2R"
          },
          "vnp_Amount": {
            "type": "number",
            "description": "Payment amount (converted back from multiplied by 100)",
            "example": 150000
          },
          "vnp_BankCode": {
            "type": "string",
            "description": "Bank code used for payment",
            "example": "NCB"
          },
          "vnp_OrderInfo": {
            "type": "string",
            "description": "Payment description from original transaction",
            "example": "Thanh toan don hang 12345"
          },
          "vnp_TransactionNo": {
            "type": "string",
            "description": "Transaction code recorded in VNPAY system",
            "example": "20170829153052"
          },
          "vnp_ResponseCode": {
            "type": "string",
            "description": "Response code from VNPAY (00 = success)",
            "example": "00"
          },
          "vnp_TransactionStatus": {
            "type": "string",
            "description": "Transaction status at VNPAY (00 = successful)",
            "example": "00"
          },
          "vnp_TxnRef": {
            "type": "string",
            "description": "Merchant transaction reference from original request",
            "example": "ORDER_12345"
          },
          "isVerified": {
            "type": "boolean",
            "description": "Whether the secure hash is verified (true = valid signature)",
            "example": false
          },
          "isSuccess": {
            "type": "boolean",
            "description": "Whether the payment is successful (true = payment processed)",
            "example": true
          },
          "message": {
            "type": "string",
            "description": "Verification result message",
            "example": "Wrong checksum"
          },
          "vnp_BankTranNo": {
            "type": "string",
            "description": "Transaction code at bank",
            "example": "NCB20170829152730"
          },
          "vnp_CardType": {
            "type": "string",
            "description": "Type of account/card used: ATM, QRCODE",
            "example": "ATM"
          },
          "vnp_PayDate": {
            "type": "string",
            "description": "Payment date - Format: yyyyMMddHHmmss",
            "example": "20170829152730"
          }
        },
        "required": [
          "vnp_TmnCode",
          "vnp_Amount",
          "vnp_BankCode",
          "vnp_OrderInfo",
          "vnp_TransactionNo",
          "vnp_ResponseCode",
          "vnp_TransactionStatus",
          "vnp_TxnRef",
          "isVerified",
          "isSuccess",
          "message"
        ]
      },
