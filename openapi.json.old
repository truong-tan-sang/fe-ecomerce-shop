              {
                "$ref": "#/components/schemas/GhnProvinceDto"
              }
            ]
          },
          "toDistrict": {
            "description": "Validated destination district information from GHN shipping system. Contains pickup/delivery types, COD support, and other shipping-related capabilities",
            "allOf": [
              {
                "$ref": "#/components/schemas/GhnDistrictDto"
              }
            ]
          },
          "toWard": {
            "description": "Validated destination ward information from GHN shipping system. Contains support type for final delivery location and delivery constraints",
            "allOf": [
              {
                "$ref": "#/components/schemas/GhnWardDto"
              }
            ]
          }
        },
        "required": [
          "toProvince",
          "toDistrict",
          "toWard"
        ]
      },
