        ]
      }
    },
    "/shipments/preview-shipping-fee": {
      "post": {
        "description": "Calculates shipping fees and delivery estimates for each package from different warehouses using GHN API. Enriches package data with shipping costs, delivery times, and pickup/delivery location details. Used in checkout flow to display shipping costs to customers before order confirmation. Does not create actual shipments.",
        "operationId": "ShipmentsController_previewShippingFeeForEachPackageForOrder",
        "parameters": [],
        "requestBody": {
          "required": true,
          "description": "Package data grouped by GHN shop ID (warehouse) and validated delivery address with GHN location IDs",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PreviewShippingFeeForPackagesDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Shipping fees calculated successfully. Returns the input packages enriched with: shipping fee amount, shipping service details (Express/Standard/Saving), expected delivery time, pickup location details (shop name/address/phone), and GHN district/ward codes for both pickup and delivery locations. Total shipping fee = sum of all package fees.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "$ref": "#/components/schemas/PackageDetailDto"
                  },
                  "description": "Object with ghnShopId as keys and enriched PackageDetail as values"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Failed to calculate shipping fees. This may occur if GHN API communication fails, invalid package dimensions provided, or shipping service unavailable for the route."
          },
          "404": {
            "description": "Not Found - Shop office not found for GHN shop ID, shop office has incomplete GHN address information (missing province/district/ward IDs), GHN province/district/ward not found in GHN system, or shipping service not available for the specified route."
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Preview shipping fees for packages before creating shipments",
        "tags": [
          "Shipments"
        ]
      }
    },
