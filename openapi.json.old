      "CreateOrderDto": {
        "type": "object",
        "properties": {
          "userId": {
            "format": "int64",
            "type": "integer",
            "example": 851
          },
          "paymentMethod": {
            "type": "object",
            "examples": [
              "COD",
              "VNPAY",
              "MOMO",
              "ZALOPAY",
              "CREDIT_CARD",
              "BANK_TRANSFER"
            ],
            "example": "COD",
