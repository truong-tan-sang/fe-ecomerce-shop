PLANE_API_KEY=your_plane_api_key
PLANE_WORKSPACE_SLUG=your_workspace
PLANE_BASE_URL=https://your-plane-instance.com
OUTLINE_API_KEY=your_outline_api_key
OUTLINE_API_URL=https://your-outline-instance.com/api

# Default assignees — used when creating items without explicit --assignees
# Leave blank to be prompted on first use (agent will list members and save your choice)
DEFAULT_INTAKE_ASSIGNEE_UUID=
DEFAULT_ITEM_ASSIGNEE_UUID=

# Media directories for /pp recordings and screenshots (optional)
# Used by /pp re/sc args to find and upload media to Outline version docs
BIBLE_RECORDINGS_DIR=
BIBLE_SCREENSHOTS_DIR=
